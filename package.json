    "@vitejs/plugin-react": "^5.0.4",
    "adm-zip": "^0.5.17",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "firebase": "^12.14.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.1",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
