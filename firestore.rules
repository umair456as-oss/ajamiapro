rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net Default-Deny-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Strict security on Licensed Madrasas collection
    match /licensed_madrasas/{madrassaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Sycned centralized madrassas data
    match /madrassas/{madrassaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User registrations
    match /users/{userId} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }

    // Public student admissions
    match /admissions/{admissionId} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }
  }
}
